# Thera-Bench Configuration
# -------------------------
# Copy this file to .env and fill in your details.

# Expert model (used for generating ground-truth and judging)
# e.g., OpenAI, Anthropic, or any other OpenAI-compatible API
EXPERT_BASE_URL=https://api.openai.com/v1
EXPERT_MODEL=gpt-4o-mini
EXPERT_API_KEY=sk-your-openai-api-key

# Candidate model (the model you want to evaluate)
# This example points to a local Ollama instance.
CANDIDATE_BASE_URL=http://localhost:11434
CANDIDATE_MODEL=llama3:8b

# Performance
# Max number of concurrent requests to any model API
MAX_CONCURRENCY=4
