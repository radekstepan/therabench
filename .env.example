# Thera-Bench Configuration
# -------------------------
# Copy this file to .env and fill in your details.

# Expert model (used for generating ground-truth and judging)
# e.g., OpenAI, Anthropic, or any other OpenAI-compatible API
EXPERT_BASE_URL=https://api.openai.com/v1
EXPERT_MODEL=gpt-4o

# --- EXPERT API KEY ---
# Option 1: Direct Key (for simple setups without a secret manager)
# EXPERT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option 2: Infisical Reference (RECOMMENDED)
# Set the value to the NAME of the secret that Infisical will inject.
# Thera-bench will automatically resolve this reference.
# Prerequisite: Run `infisical init` and ensure your Infisical project
# has a secret named OPENAI_API_KEY (or whatever you specify here).
EXPERT_API_KEY=OPENAI_API_KEY

# Candidate model (the model you want to evaluate)
# This example points to a local Ollama instance.
CANDIDATE_BASE_URL=http://192.168.1.72:1234/v1
CANDIDATE_MODEL=gemma-3-27B-it

# Performance
# Max number of concurrent requests to any model API
MAX_CONCURRENCY=1
