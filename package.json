{
  "name": "thera-bench",
  "version": "1.0.3",
  "description": "A batteries-included framework for evaluating LLM performance against a ground-truth dataset.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "thera-bench": "bin/thera-bench-cli.js"
  },
  "files": [
    "dist/",
    "bin/",
    "schema.sql"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "infisical run -- tsx src/index.ts",
    "bench:init": "infisical run -- tsx src/index.ts init",
    "bench:eval": "infisical run -- tsx src/index.ts eval",
    "bench:report": "infisical run -- tsx src/index.ts report",
    "bench:replay": "infisical run -- tsx src/index.ts replay",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "llm",
    "benchmark",
    "evaluation",
    "ollama",
    "openai",
    "infisical"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "p-limit": "^5.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.14.2",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
